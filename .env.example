# Copy this file to .env and provide local values. Never commit real secrets.
ADS_API_URL=http://192.168.0.103:4000/api/v1/common/advertiser/names
ADS_API_TOKEN=replace_with_ads_api_token
ADS_API_MODE=mock
ADS_API_MAX_PAGES=1
APOLLO_API_KEY=replace_with_apollo_api_key
APOLLO_MODE=mock
APOLLO_BASE_URL=https://api.apollo.io/api/v1
APOLLO_CONTACTS_PER_COMPANY=3
APOLLO_CONCURRENCY=3
APOLLO_REQUIRE_VERIFIED_EMAIL=true
APOLLO_REVEAL_PERSONAL_EMAILS=true
# Mobile numbers are asynchronous. Configure these after a public HTTPS API URL exists.
# Example URL: https://api.example.com/api/webhooks/apollo?token=the_same_secret_below
# APOLLO_WEBHOOK_URL=
# APOLLO_WEBHOOK_SECRET=replace_with_at_least_24_random_characters

# Required AI enrichment. Use live after adding a Google AI Studio API key.
GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_MODE=mock
GEMINI_MODEL=gemini-3.5-flash
GEMINI_CONCURRENCY=3

# SendGrid mail delivery. The from address must be verified in SendGrid.
MAIL_MODE=mock
SENDGRID_API_KEY=replace_with_sendgrid_api_key
SENDGRID_FROM_EMAIL=verified-sender@example.com
SENDGRID_FROM_NAME=Power Leads
SENDGRID_WEBHOOK_PUBLIC_KEY=replace_with_sendgrid_event_webhook_public_key
SENDGRID_WEBHOOK_MAX_AGE_SECONDS=300
MAIL_PER_RUN_LIMIT=50
MAIL_DAILY_WORKSPACE_LIMIT=100
MAIL_CONCURRENCY=3

# Application infrastructure
MONGO_URI=mongodb://127.0.0.1:27018/power_leads
PORT=4001
NODE_ENV=development
TRUST_PROXY=false
CORS_ORIGINS=http://localhost:5173
API_RATE_LIMIT_MAX=1000
PIPELINE_MAX_ATTEMPTS=3
WORKER_POLL_MS=1000
WORKER_LEASE_MS=60000
RUN_ADS_CALL_BUDGET=100
RUN_GEMINI_CALL_BUDGET=300
RUN_APOLLO_CALL_BUDGET=1000
AUTH_MODE=development
AUTH_PROXY_SHARED_SECRET=replace_with_at_least_32_random_characters
APP_BASE_URL=http://localhost:5173
SESSION_COOKIE_NAME=power_leads_session
SESSION_TTL_HOURS=168
AUTH_TOKEN_TTL_HOURS=24
# Set BOOTSTRAP_ADMIN_EMAIL and BOOTSTRAP_ADMIN_PASSWORD temporarily only
# when running the create-admin script, then remove them.
BOOTSTRAP_ADMIN_NAME=Administrator
DEV_AUTH_USER_ID=local-user
DEV_AUTH_WORKSPACE_ID=local-workspace
DEV_AUTH_ROLE=admin
